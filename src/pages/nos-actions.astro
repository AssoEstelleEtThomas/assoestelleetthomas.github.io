---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import { MessageCircle, Users, BookOpen, ClipboardList } from "@lucide/astro";
---

<BaseLayout title="Nos actions" description="Découvrez les actions de l'Association Estelle & Thomas : groupes de parole, sensibilisation et ateliers thématiques.">
  <!-- Script Tally (popup) — chargé dans le <head> via le slot du layout -->
  <script is:inline slot="head" async src="https://tally.so/widgets/embed.js"></script>

  <PageHero
    title="Nos actions"
    subtitle="Agir concrètement contre le harcèlement scolaire"
  />

  <!-- Groupes de parole -->
  <section class="bg-background py-24">
    <div class="max-w-[1200px] mx-auto px-5">
      <div class="flex flex-col lg:flex-row items-center gap-12 reveal">
        <div class="flex-1">
          <h2 class="font-display font-black text-3xl text-primary mb-6">Groupes de parole</h2>
          <p class="text-text leading-relaxed mb-4">
            <strong>Partager, écouter et pouvoir se reconstruire ensemble.</strong> Nous offrons des espaces d'expression sécurisés et bienveillants pour libérer la parole et rompre l'isolement.
          </p>
          <p class="text-text leading-relaxed">
            Nos sessions adaptées accueillent les enfants, les parents, ainsi que les familles (enfants &amp; parents) pour échanger et avancer ensemble.
          </p>
          <p class="text-text leading-relaxed mt-6 font-semibold">
            Aidez-nous à créer ce groupe de parole : partagez vos attentes en quelques minutes. Questionnaire anonyme.
          </p>
          <button
            type="button"
            data-tally-open="ODg4P8"
            data-tally-layout="modal"
            data-tally-width="700"
            data-tally-overlay="1"
            class="inline-flex items-center gap-2 mt-6 px-8 py-4 rounded-pill bg-accent text-white font-display font-bold shadow-lg shadow-accent/30 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-accent/40 transition-all cursor-pointer"
          >
            <ClipboardList class="w-5 h-5" />
            Remplir le questionnaire
          </button>
        </div>
        <div class="flex-1 flex justify-center">
          <div class="w-full max-w-[400px] h-64 rounded-card bg-secondary/20 flex items-center justify-center">
            <MessageCircle class="w-20 h-20 text-primary/30" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sensibilisation -->
  <section class="bg-card py-24">
    <div class="max-w-[1200px] mx-auto px-5">
      <div class="flex flex-col lg:flex-row-reverse items-center gap-12 reveal">
        <div class="flex-1">
          <h2 class="font-display font-black text-3xl text-primary mb-6">Sensibilisation</h2>
          <p class="text-text leading-relaxed mb-4">
            <strong>Informer pour prévenir et désamorcer.</strong> Parce que la lutte contre le harcèlement commence par la prévention, nous intervenons auprès des scolaires, des structures jeunesse et du grand public.
          </p>
          <p class="text-text leading-relaxed">
            Notre but : éveiller les consciences, développer l'empathie et former les adultes à repérer les signaux d'alerte.
          </p>
        </div>
        <div class="flex-1 flex justify-center">
          <div class="w-full max-w-[400px] h-64 rounded-card bg-accent/10 flex items-center justify-center">
            <Users class="w-20 h-20 text-accent/30" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Ateliers thématiques -->
  <section class="bg-background py-24">
    <div class="max-w-[1200px] mx-auto px-5">
      <div class="flex flex-col lg:flex-row items-center gap-12 reveal">
        <div class="flex-1">
          <h2 class="font-display font-black text-3xl text-primary mb-6">Ateliers thématiques</h2>
          <p class="text-text leading-relaxed mb-4">
            <strong>Des outils pratiques et ludiques pour agir.</strong> Nous animons des ateliers ciblés pour développer des compétences concrètes : gestion des émotions, estime de soi, confiance en soi, ou encore utilisation sereine des réseaux sociaux.
          </p>
          <p class="text-text leading-relaxed">
            Des moments interactifs pour donner aux jeunes et aux adultes les clés de la résilience.
          </p>
        </div>
        <div class="flex-1 flex justify-center">
          <div class="w-full max-w-[400px] h-64 rounded-card bg-dark/10 flex items-center justify-center">
            <BookOpen class="w-20 h-20 text-dark/30" />
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<ScrollReveal />
