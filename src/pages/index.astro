---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import persos from "../assets/images/persos.png";
---

<BaseLayout title="Accueil">
  <!-- Banner -->
  <div class="bg-accent text-white text-center py-2 font-display font-semibold text-sm">
    <p>Site en construction</p>
  </div>

  <!-- Hero -->
  <section id="accueil" class="bg-gradient-to-br from-secondary to-secondary-light pb-20 pt-16 relative overflow-hidden rounded-b-[0_0_50%_50%/0_0_4rem_4rem]" style="border-radius: 0 0 50% 50% / 0 0 4rem 4rem;">
    <div class="max-w-[1200px] mx-auto px-5 flex flex-col-reverse lg:flex-row items-center justify-between gap-8 lg:gap-16 relative z-10">
      <div class="flex-1 max-w-[600px] text-center lg:text-left">
        <h1 class="font-display font-black text-4xl md:text-5xl lg:text-[3.5rem] leading-tight text-white mb-6 hero-animate-title">
          Ensemble contre le harcèlement scolaire
        </h1>
        <p class="font-display font-normal text-xl text-primary mb-10 hero-animate-subtitle">
          Écoute, soutien et bienveillance pour les élèves et leurs familles.
        </p>
        <div class="flex gap-4 justify-center lg:justify-start hero-animate-cta">
          <a
            href="#contact"
            class="inline-block px-8 py-4 rounded-pill bg-accent text-white font-display font-bold shadow-lg shadow-accent/30 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-accent/40 transition-all"
          >
            Nous contacter
          </a>
          <a
            href="#a-propos"
            class="inline-block px-8 py-4 rounded-pill border-2 border-primary text-primary font-display font-bold hover:bg-primary hover:text-white transition-all"
          >
            En savoir plus
          </a>
        </div>
      </div>
      <div class="flex-1 flex justify-center items-center hero-animate-image">
        <Image
          src={persos}
          alt="Illustration des personnages"
          class="max-w-full h-auto max-h-[500px] object-contain drop-shadow-2xl"
        />
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="a-propos" class="bg-background py-24 reveal">
    <div class="max-w-[1200px] mx-auto px-5 text-center">
      <h2 class="font-display font-black text-4xl text-primary mb-8">
        Qui sommes-nous ?
      </h2>
      <div class="max-w-[800px] mx-auto">
        <p class="text-lg text-text font-semibold mb-6 leading-relaxed">
          Présidée par <strong>Estelle Masson</strong>, notre association lutte activement contre le
          harcèlement scolaire.
          Nous souhaitons nous démarquer par une communication positive, rassurante et inclusive, loin des
          messages culpabilisants ou anxiogènes.
        </p>
        <p class="text-lg text-text font-semibold leading-relaxed">
          Notre volonté est de mettre en avant l'idée d'accompagnement, de solidarité et de réconfort.
        </p>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section id="valeurs" class="bg-card py-24">
    <div class="max-w-[1200px] mx-auto px-5">
      <h2 class="font-display font-black text-4xl text-primary mb-8 text-center reveal">
        Nos Valeurs
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12 stagger-children">
        <div class="card-hover p-10 rounded-card text-center border border-black/5 bg-secondary/10">
          <h3 class="font-display font-black text-2xl text-primary mb-4">Partage</h3>
          <p class="text-text font-semibold">Créer des liens et échanger ensemble pour mieux comprendre et agir.</p>
        </div>
        <div class="card-hover p-10 rounded-card text-center border border-black/5 bg-dark/10">
          <h3 class="font-display font-black text-2xl text-primary mb-4">Écoute</h3>
          <p class="text-text font-semibold">Un espace bienveillant où chacun peut s'exprimer librement.</p>
        </div>
        <div class="card-hover p-10 rounded-card text-center border border-black/5 bg-accent/10">
          <h3 class="font-display font-black text-2xl text-primary mb-4">Soutien</h3>
          <p class="text-text font-semibold">Accompagner avec empathie et solidarité dans chaque étape.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
        }
      });
    },
    { threshold: 0.15 }
  );

  document.querySelectorAll(".reveal, .stagger-children").forEach((el) => {
    observer.observe(el);
  });
</script>
