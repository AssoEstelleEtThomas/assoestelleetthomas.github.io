---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import ValueCard from "../components/ValueCard.astro";
import LinkCard from "../components/LinkCard.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import persos from "../assets/images/persos.png";
---

<BaseLayout title="Accueil">
  <!-- Banner -->
  <div class="bg-accent text-white text-center py-2 font-display font-semibold text-sm">
    <p>Site en construction</p>
  </div>

  <!-- Hero -->
  <div class="bg-card">
  <section class="bg-gradient-to-br from-secondary to-secondary-light pb-20 pt-16 relative overflow-hidden" style="border-radius: 0 0 50% 50% / 0 0 4rem 4rem;">
    <div class="max-w-[1200px] mx-auto px-5 flex flex-col-reverse lg:flex-row items-center justify-between gap-8 lg:gap-16 relative z-10">
      <div class="flex-1 max-w-[600px] text-center lg:text-left">
        <h1 class="font-display font-black text-4xl md:text-5xl lg:text-[3.5rem] leading-tight text-white mb-6 hero-animate-title">
          Ensemble contre le harcèlement scolaire
        </h1>
        <p class="font-display font-normal text-xl text-primary mb-10 hero-animate-subtitle">
          Écoute, soutien et bienveillance pour les élèves et leurs familles.
        </p>
        <div class="flex gap-4 justify-center lg:justify-start hero-animate-cta">
          <a
            href="/contact"
            class="inline-block px-8 py-4 rounded-pill bg-accent text-white font-display font-bold shadow-lg shadow-accent/30 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-accent/40 transition-all"
          >
            Nous contacter
          </a>
          <a
            href="/qui-sommes-nous"
            class="inline-block px-8 py-4 rounded-pill border-2 border-primary text-primary font-display font-bold hover:bg-primary hover:text-white transition-all"
          >
            En savoir plus
          </a>
        </div>
      </div>
      <div class="flex-1 flex justify-center items-center hero-animate-image">
        <Image
          src={persos}
          alt="Illustration des personnages"
          class="max-w-full h-auto max-h-[500px] object-contain drop-shadow-2xl"
        />
      </div>
    </div>
  </section>
  </div>

  <!-- Values -->
  <section class="bg-card py-24">
    <div class="max-w-[1200px] mx-auto px-5">
      <h2 class="font-display font-black text-4xl text-primary mb-8 text-center reveal">
        Nos Valeurs
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12 stagger-children">
        <ValueCard
          title="Partage"
          description="Créer des liens et échanger ensemble pour mieux comprendre et agir."
          bgClass="bg-secondary/10"
        />
        <ValueCard
          title="Écoute"
          description="Un espace bienveillant où chacun peut s'exprimer librement."
          bgClass="bg-dark/10"
        />
        <ValueCard
          title="Soutien"
          description="Accompagner avec empathie et solidarité dans chaque étape."
          bgClass="bg-accent/10"
        />
      </div>
    </div>
  </section>

  <!-- Stats & Testimonials -->
  <section class="bg-background py-24 reveal">
    <div class="max-w-[1200px] mx-auto px-5">
      <h2 class="font-display font-black text-4xl text-primary mb-16 text-center">
        Le harcèlement scolaire en chiffres
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16 stagger-children">
        <div class="text-center">
          <p class="font-display font-black text-5xl text-accent mb-3">1 sur 10</p>
          <p class="text-text font-semibold">élèves est victime de harcèlement scolaire en France</p>
        </div>
        <div class="text-center">
          <p class="font-display font-black text-5xl text-accent mb-3">700 000</p>
          <p class="text-text font-semibold">enfants sont touchés chaque année</p>
        </div>
        <div class="text-center">
          <p class="font-display font-black text-5xl text-accent mb-3">3020</p>
          <p class="text-text font-semibold">le numéro national contre le harcèlement scolaire</p>
        </div>
      </div>

      <div class="max-w-[800px] mx-auto bg-card rounded-card p-8 border-l-4 border-accent reveal">
        <blockquote class="text-lg text-text italic leading-relaxed mb-4">
          « Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris. »
        </blockquote>
        <p class="text-accent font-display font-semibold">— Lorem Ipsum, parent d'élève</p>
      </div>
    </div>
  </section>

  <!-- Discover pages -->
  <section class="bg-card py-24">
    <div class="max-w-[1200px] mx-auto px-5">
      <h2 class="font-display font-black text-4xl text-primary mb-12 text-center reveal">
        Découvrir l'association
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
        <LinkCard
          href="/qui-sommes-nous"
          title="Qui sommes-nous"
          description="Découvrez l'équipe engagée derrière l'association et notre mission."
        />
        <LinkCard
          href="/nos-actions"
          title="Nos actions"
          description="Groupes de parole, sensibilisation, ateliers : nos actions concrètes."
        />
        <LinkCard
          href="/ressources"
          title="Ressources"
          description="Podcasts, articles et liens utiles pour comprendre et agir."
        />
      </div>
    </div>
  </section>
</BaseLayout>

<ScrollReveal />
