---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
---

<BaseLayout title="Contact" description="Contactez l'Association Estelle & Thomas pour toute question sur le harcèlement scolaire.">
  <PageHero
    title="Contactez-nous"
    subtitle="Une question, un témoignage, une envie de nous rejoindre ?"
  />

  <section class="bg-background py-24">
    <div class="max-w-[600px] mx-auto px-5 reveal">
      <form class="bg-card rounded-card p-8 md:p-12 shadow-sm border border-black/5">
        <div class="mb-6">
          <label for="name" class="block font-display font-semibold text-primary mb-2">Nom</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-3 rounded-card border border-black/10 bg-background font-sans text-text focus:outline-none focus:ring-2 focus:ring-accent"
            placeholder="Votre nom"
          />
        </div>
        <div class="mb-6">
          <label for="email" class="block font-display font-semibold text-primary mb-2">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-3 rounded-card border border-black/10 bg-background font-sans text-text focus:outline-none focus:ring-2 focus:ring-accent"
            placeholder="votre@email.com"
          />
        </div>
        <div class="mb-8">
          <label for="message" class="block font-display font-semibold text-primary mb-2">Message</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="w-full px-4 py-3 rounded-card border border-black/10 bg-background font-sans text-text focus:outline-none focus:ring-2 focus:ring-accent resize-y"
            placeholder="Votre message..."
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full px-8 py-4 rounded-pill bg-accent text-white font-display font-bold shadow-lg shadow-accent/30 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-accent/40 transition-all"
        >
          Envoyer
        </button>
        <p class="text-text/50 text-sm text-center mt-4">
          Ce formulaire est en cours de mise en place.
        </p>
      </form>
    </div>
  </section>
</BaseLayout>

<ScrollReveal />
