---
import { ArrowRight } from "@lucide/astro";

interface Props {
  href: string;
  title: string;
  description: string;
}

const { href, title, description } = Astro.props;
---

<a href={href} class="card-hover block p-8 rounded-card border border-black/5 bg-card group">
  <h3 class="font-display font-black text-xl text-primary mb-3 group-hover:text-accent transition-colors">
    {title}
  </h3>
  <p class="text-text/80 mb-4">{description}</p>
  <span class="inline-flex items-center gap-2 text-accent font-display font-semibold text-sm">
    Découvrir <ArrowRight class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
  </span>
</a>
