---
import { Image } from "astro:assets";
import SocialIcons from "./SocialIcons.astro";
import logo from "../assets/images/logo.png";

const links = [
  { href: "/", label: "Accueil" },
  { href: "/qui-sommes-nous", label: "Qui sommes-nous" },
  { href: "/nos-actions", label: "Nos actions" },
  { href: "/ressources", label: "Ressources" },
  { href: "/contact", label: "Contact" },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-card/80 backdrop-blur-sm sticky top-0 z-50 shadow-sm">
  <nav class="flex justify-between items-center w-full px-6 py-3 max-w-[1200px] mx-auto">
    <a href="/" class="flex items-center">
      <Image
        src={logo}
        alt="Logo Association Estelle & Thomas"
        height={60}
        class="h-15 w-auto"
      />
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            "nav-link font-display font-semibold text-dark transition-colors duration-200 hover:text-accent",
            { "nav-link-active": href === "/" ? currentPath === "/" : currentPath.startsWith(href) },
          ]}
        >
          {label}
        </a>
      ))}
      <SocialIcons class="flex items-center gap-3 ml-2 text-primary" />
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-text p-2"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
    >
      <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-card border-t border-dark/10 pb-4">
    <ul class="flex flex-col px-6 py-4 gap-3">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              "font-display font-semibold text-lg py-2 text-text hover:text-accent transition-colors block",
              { "text-accent": href === "/" ? currentPath === "/" : currentPath.startsWith(href) },
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
    <div class="px-6 pt-2 border-t border-dark/10">
      <SocialIcons class="flex items-center gap-4 text-primary" />
    </div>
  </div>
    <!-- Banner -->
  <div class="bg-accent text-white text-center py-2 font-display font-semibold text-sm">
    <p>🚧👷‍♀️ Site en construction</p>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    btn.setAttribute("aria-expanded", String(!isOpen));
  });
</script>
