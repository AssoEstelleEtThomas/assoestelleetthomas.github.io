---
import { Mail } from "@lucide/astro";
---

<footer class="bg-primary text-white">
  <div class="max-w-[1200px] mx-auto px-6 pt-16 pb-8">
    <div class="flex flex-col md:flex-row justify-between items-start gap-8 mb-12">
      <div>
        <h3 class="font-display font-black text-2xl text-white mb-2">
          Association Estelle & Thomas
        </h3>
        <p class="text-white/80">Ensemble contre le harcèlement scolaire</p>
      </div>
      <div>
        <h4 class="font-display font-semibold text-lg text-secondary mb-3">
          Contactez-nous
        </h4>
        <a
          href="mailto:contact.assoestelleetthomas@gmail.com"
          class="flex items-center gap-3 hover:text-secondary transition-colors"
        >
          <span class="w-10 h-10 rounded-full border-2 border-white/30 flex items-center justify-center">
            <Mail class="w-5 h-5" />
          </span>
          <span class="font-semibold">contact.assoestelleetthomas@gmail.com</span>
        </a>
        <div class="flex items-center gap-3 mt-4">
          <a href="https://www.instagram.com/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full border-2 border-white/30 flex items-center justify-center hover:text-secondary hover:border-secondary transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5" />
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />
            </svg>
          </a>
          <a href="https://www.facebook.com/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full border-2 border-white/30 flex items-center justify-center hover:text-secondary hover:border-secondary transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
            </svg>
          </a>
        </div>
        <p class="text-white/60 text-sm mt-3">RNA : W141005251</p>
      </div>
    </div>

    <div class="border-t border-white/15 pt-6 text-center text-sm text-white/50">
      <p>&copy; {new Date().getFullYear()} Association Estelle & Thomas. Tous droits réservés.</p>
    </div>
  </div>
</footer>
