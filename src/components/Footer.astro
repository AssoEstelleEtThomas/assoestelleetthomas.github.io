---
import { Mail } from "@lucide/astro";
---

<footer id="contact" class="bg-primary text-white">
  <div class="max-w-[1200px] mx-auto px-6 pt-16 pb-8">
    <div class="flex flex-col md:flex-row justify-between items-start gap-8 mb-12">
      <div>
        <h3 class="font-display font-black text-2xl text-white mb-2">
          Association Estelle & Thomas
        </h3>
        <p class="text-white/80">Ensemble contre le harcèlement scolaire</p>
      </div>
      <div>
        <h4 class="font-display font-semibold text-lg text-secondary mb-3">
          Contactez-nous
        </h4>
        <a
          href="mailto:contact.assoestelleetthomas@gmail.com"
          class="flex items-center gap-3 hover:text-secondary transition-colors"
        >
          <span class="w-10 h-10 rounded-full border-2 border-white/30 flex items-center justify-center">
            <Mail class="w-5 h-5" />
          </span>
          <span class="font-semibold">contact.assoestelleetthomas@gmail.com</span>
        </a>
        <p class="text-white/60 text-sm mt-3">RNA : W141005251</p>
      </div>
    </div>

    <div class="border-t border-white/15 pt-6 text-center text-sm text-white/50">
      <p>&copy; {new Date().getFullYear()} Association Estelle & Thomas. Tous droits réservés.</p>
    </div>
  </div>
</footer>
