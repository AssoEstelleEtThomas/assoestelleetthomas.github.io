---
interface Props {
  title: string;
  subtitle?: string;
  id?: string;
}

const { title, subtitle, id } = Astro.props;
---

<div class="text-center mb-12 reveal" id={id}>
  <h2 class="font-display font-black text-4xl text-primary mb-4">
    {title}
  </h2>
  {subtitle && (
    <p class="text-lg text-text/80 max-w-[600px] mx-auto">
      {subtitle}
    </p>
  )}
</div>
