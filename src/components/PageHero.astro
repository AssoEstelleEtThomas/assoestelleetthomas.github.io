---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="pt-16 pb-8 relative overflow-hidden">
  <div class="max-w-[1200px] mx-auto px-5 text-center">
    <h1
      class="font-display font-black text-4xl md:text-5xl text-accent hero-animate-title"
    >
      {title}
    </h1>
    {
      subtitle && (
        <p class="font-display text-xl text-primary mt-4 hero-animate-subtitle">
          {subtitle}
        </p>
      )
    }
    <div
      class="mx-auto mt-6 w-[30%] h-[4px] bg-accent rounded-full hero-animate-title"
    >
    </div>
  </div>
</section>
