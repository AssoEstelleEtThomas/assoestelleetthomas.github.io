---
interface Props {
  class?: string;
  iconClass?: string;
}

const { class: className = "", iconClass = "w-5 h-5" } = Astro.props;
---

<div class={className}>
  <a href="https://www.instagram.com/estelle_thomas_/" target="_blank" rel="noopener noreferrer" class="text-inherit hover:text-accent transition-colors" aria-label="Instagram">
    <svg class={iconClass} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect width="20" height="20" x="2" y="2" rx="5" ry="5" />
      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
      <line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />
    </svg>
  </a>
  <a href="https://www.facebook.com/people/Estelle-et-Thomas-contre-le-harc%C3%A8lement-scolaire/61579563773547/" target="_blank" rel="noopener noreferrer" class="text-inherit hover:text-accent transition-colors" aria-label="Facebook">
    <svg class={iconClass} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
    </svg>
